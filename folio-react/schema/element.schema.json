                "strokeColor": {
                    "type": "string",
                    "description": "The color of the arrow stroke. Default is #000000",
                    "default": "#000000"
                },
                "strokeWidth": {
                    "type": "number",
                    "description": "The width of the arrow stroke. Default is 1",
                    "default": 1
                },
                "strokeStyle": {
                    "type": "string",
                    "enum": [
                        "none",
                        "solid",
                        "dashed",
                        "dotted"
                    ],
                    "description": "The style of the arrow stroke. Default is solid",
                    "default": "solid"
                },
                "opacity": {
                    "type": "number",
                    "description": "The opacity of the element (0.0 to 1.0). Default is 1.0",
                    "default": 1.0
                }
            },
            "required": [
                "type",
                "x1",
                "y1",
                "x2",
                "y2"
            ]
