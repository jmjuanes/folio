<!doctype html>
<html lang="en" style="overscroll-behavior-x:none;">
{{>folio::head}}
<body class="m-0 p-0 font-sans leading-normal bg-white text-gray-950">
    <header class="flex items-center justify-between w-full px-6 py-6">
        {{>folio::logo variant="dark"}}
        {{#if @site.navbar.links}}
        <div class="hidden md:flex gap-6 items-center">
            {{#each @site.navbar.links}}
            <a href="{{this.href}}" class="cursor-pointer hover:underline text-current text-base">
                <span>{{this.text}}</span>
            </a>
            {{/each}}
        </div>
        {{/if}}
        {{#if @site.navbar.callToAction}}
        <a href="{{@site.navbar.callToAction.href}}" class="hidden sm:flex items-center gap-1 px-3 py-2 bg-gray-950 text-white rounded-xl hover:opacity-90">
            <span class="font-medium text-base">{{@site.navbar.callToAction.text}}</span>
            <div class="flex items-center text-lg">
                {{>folio::icon icon="arrow-right" className=""}}
            </div>
        </a>
        {{/if}}
    </header>
    <main class="w-full px-6 py-0">
        <div class="w-full flex flex-row flex-nowrap md:gap-12">
            <div class="hidden lg:block w-56 shrink-0">
                <div class="sticky flex flex-col gap-8 top-0 h-screen overflow-y-auto overflow-x-hidden py-4">
                    {{#each @site.sidebar}}
                    <div class="">
                        <div class="mb-2 text-sm font-bold">
                            <span>{{this.group}}</span>
                        </div>
                        {{#each this.pages}}
                        {{#withPage this}}
                        <a href="{{this.attributes.permalink}}" class="flex text-sm mb-1 font-medium text-current {{#eq this.attributes.permalink @page.permalink}}bg-gray-100 font-bold{{/eq}} hover:bg-gray-100 rounded-lg px-3 py-2">
                            <span class="leading-tight opacity-70">{{this.attributes.title}}</span>
                        </a>
                        {{/withPage}}
                        {{/each}}
                    </div>
                    {{/each}}
                </div>
            </div>
            <div class="w-full max-w-3xl min-w-0 mx-auto pt-4 pb-16 flex flex-col gap-12">
                <div class="">
                    <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-0 mt-0 leading-none">
                        <span>{{!@page.title}}</span>
                    </h1>
                    {{#if @page.description}}
                    <div class="mt-3 text-lg sm:text-xl opacity-70 leading-relaxed">
                        <span>{{!@page.description}}</span>
                    </div>
                    {{/if}}
                </div>
                <div class="prose">
                {{#markdown}}
                    {{!@content}}
                {{/markdown}}
                </div>
                <div class="grid items-center grid-cols-2 gap-4">
                    <div class="w-full flex justify-start">
                    {{#if @page.prevPage}}
                        {{#withPage @page.prevPage}}
                        <a href="{{this.attributes.permalink}}" class="flex flex-nowrap justify-start items-center gap-2 opacity-60 hover:opacity-100">
                            <div class="flex items-center text-xl">
                                {{>folio::icon icon="chevron-left"}}
                            </div>
                            <div class="font-medium">{{this.attributes.title}}</div>
                        </a>
                        {{/withPage}}
                    {{/if}}
                    </div>
                    <div class="w-full flex justify-end">
                    {{#if @page.nextPage}}
                        {{#withPage @page.nextPage}}
                        <a href="{{this.attributes.permalink}}" class="flex flex-nowrap justify-end items-center gap-2 opacity-60 hover:opacity-100">
                            <div class="font-medium">{{this.attributes.title}}</div>
                            <div class="flex items-center text-xl">
                                {{>folio::icon icon="chevron-right"}}
                            </div>
                        </a>
                        {{/withPage}}
                    {{/if}}
                    </div>
                </div>
            </div>
            <div class="hidden xl:block w-56 shrink-0">
                <div class="sticky top-0 py-12 text-sm flex flex-col gap-2">
                    <div class="flex items-center gap-2 opacity-80 mb-2">
                        <div class="text-base flex items-center">
                            {{>folio::icon icon="text-left"}}
                        </div>
                        <div class="font-medium">On this page</div>
                    </div>
                    {{#each @toc}}
                    <a href="#{{this.slug}}" class="block font-medium text-current hover:underline" style="margin-left: calc({{this.level}}rem - 2rem);">
                        <span>{{this.text}}</span>
                    </a>
                    {{/each}}
                </div>
            </div>
        </div>
    </main>
</body>
</html>
