                                {
                                    "heading": "Folio Lite",
                                    "headingClassName": "text-2xl",
                                    "description": "Open your browser and start drawing. No account, no setup, no friction. Perfect for quick ideas, sketches on the fly, or anyone who just wants to get started immediately.",
