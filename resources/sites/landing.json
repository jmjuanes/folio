                                    "linkText": "Try it now &rarr;",
                                    "linkHref": "/app",
                                    "linkClassName": "text-current border-2 border-gray-950"
                                },
                                {
                                    "heading": "Folio Studio",
                                    "headingClassName": "text-2xl",
                                    "description": "Run Folio on your own machine or server via Docker. Unlimited boards, full data ownership, and zero external dependencies. Built for teams and power users who want complete control.",
                                    "image": "/images/folio-studio-preview.png",
                                    "linkText": "Learn more &rarr;",
                                    "linkHref": "/studio",
                                    "linkClassName": "text-current border-2 border-gray-950"
