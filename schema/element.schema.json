{
    "oneOf": [
        {
            "type": "object",
            "description": "A geometric shape element",
            "properties": {
                "type": {
                    "enum": [
                        "shape"
                    ],
                    "description": "The type of the element"
                },
                "shape": {
                    "type": "string",
                    "enum": [
                        "rectangle",
                        "ellipse",
                        "diamond",
                        "triangle"
                    ],
                    "description": "The geometric shape type"
                },
                "x1": {
                    "type": "number",
                    "description": "The x coordinate of the top-left corner of the shape bounds"
                },
                "y1": {
                    "type": "number",
                    "description": "The y coordinate of the top-left corner of the shape bounds"
                },
                "x2": {
                    "type": "number",
                    "description": "The x coordinate of the bottom-right corner of the shape bounds"
                },
                "y2": {
                    "type": "number",
                    "description": "The y coordinate of the bottom-right corner of the shape bounds"
                },
                "fillColor": {
                    "type": "string",
                    "description": "The fill color of the shape (e.g. #ff0000, transparent, etc.). Default is transparent",
                    "default": "transparent"
                },
                "fillStyle": {
                    "type": "string",
                    "enum": [
                        "none",
                        "hatch",
                        "transparent",
                        "solid"
                    ],
                    "description": "The fill style pattern. Default is solid",
                    "default": "solid"
                },
                "strokeColor": {
                    "type": "string",
                    "description": "The color of the shape's border (only hex colors and 'transparent' are supported). Default is #000000",
                    "default": "#000000"
                },
                "strokeWidth": {
                    "type": "number",
                    "description": "The width of the shape's border in pixels. Default is 1",
                    "default": 1
                },
                "strokeStyle": {
                    "type": "string",
                    "enum": [
                        "none",
                        "solid",
                        "dashed",
                        "dotted"
                    ],
                    "description": "The style of the shape's border. Default is solid",
                    "default": "solid"
                },
                "opacity": {
                    "type": "number",
                    "description": "The opacity of the element (0.0 to 1.0). Default is 1.0",
                    "default": 1.0
                },
                "rotation": {
                    "type": "number",
                    "description": "The rotation in degrees of the element. Default is 0",
                    "default": 0
                }
            },
            "required": [
                "type",
                "shape",
                "x1",
                "y1",
                "x2",
                "y2",
                "fillColor",
                "fillStyle",
                "strokeColor",
                "strokeWidth",
                "strokeStyle",
                "opacity",
                "rotation"
            ],
            "additionalProperties": false
        },
