{
    "name": "folio",
    "version": "0.29.0",
    "description": "A minimalistic digital whiteboard for sketching and prototyping",
    "private": true,
    "type": "module",
    "homepage": "https://www.josemi.xyz/folio",
    "repository": "https://github.com/jmjuanes/folio",
    "author": "Josemi Juanes <hello@josemi.xyz>",
    "bugs": "https://github.com/jmjuanes/folio/issues",
    "workspaces": [
        "folio-app",
        "folio-react",
        "workers/*"
    ],
    "scripts": {
        "build": "yarn build:studio",
        "build:ai": "yarn workspace folio-ai build",
        "build:app": "yarn build:studio",
        "build:shared": "yarn workspace folio-shared build",
        "build:auth": "yarn workspace folio-auth build",
        "build:storage": "yarn workspace folio-storage build",
        "build:dist": "cross-env NODE_ENV=production webpack build",
        "build:docker": "docker build -f ./Dockerfile -t folio-studio .",
        "build:docs": "node scripts/site.js -c resources/sites/documentation.json -o .cache/documentation && node scripts/copy-assets.js -o .cache/documentation",
        "build:lite": "yarn workspace folio-lite build",
        "build:landing": "node scripts/site.js -c resources/sites/landing.json -o .cache/landing && node scripts/copy-assets.js -o .cache/landing",
        "build:website": "yarn build:docs && yarn build:landing",
        "build:workers": "yarn build:shared && yarn build:auth && yarn build:storage",
        "prebuild:dist": "node scripts/obfuscate-css.js --input node_modules/lowcss/low.css --input node_modules/lowcss-helpers/index.css --output obfuscate.map.json",
        "postbuild:dist": "node scripts/purge-css.js --input folio-react/folio.js --output folio-react/folio.css --config obfuscate.map.json",
        "copy:app": "yarn copy:studio",
        "copy:studio": "yarn clean && cp -R apps/studio/www www",
        "copy:website": "yarn clean && mkdir www && cp -R .cache/documentation/* www && cp -R .cache/landing/* www/",
        "clean": "rm -rf www",
        "deploy:ai": "yarn workspace folio-ai deploy",
        "dev": "serve www -p 8080",
        "dev:app": "yarn dev:studio",
        "dev:docs": "serve .cache/documentation -p 8080",
        "dev:landing": "serve .cache/landing -p 8080",
        "dev:lite": "cross-env NODE_ENV=development yarn workspace folio-lite dev",
        "dev:studio": "cross-env NODE_ENV=development yarn workspace folio-studio dev",
        "start:auth": "cross-env NODE_ENV=development DEBUG='folio:*' node --conditions=development folio.js start:auth --port 3001",
        "start:storage": "cross-env NODE_ENV=development DEBUG='folio:*' node folio.js --conditions=development start:storage --port 3002",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "typecheck": "yarn typecheck:workers",
        "typecheck:workers": "yarn workspace folio-shared typecheck",
        "typecheck:lite": "yarn workspace folio-lite typecheck"
    },
    "imports": {
        "#folio-shared": {
            "development": "./workers/shared/dist/index.js"
        },
        "#folio-auth": {
            "development": "./workers/auth/dist/index.js"
        },
        "#folio-storage": {
            "development": "./workers/storage/dist/index.js"
        }
    },
    "dependencies": {
        "@josemi-icons/svg": "^0.7.0",
        "lowcss": "^0.33.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@babel/core": "^8.0.1",
        "@babel/plugin-transform-runtime": "^8.0.1",
        "@babel/preset-env": "^8.0.2",
        "@babel/preset-react": "^8.0.1",
        "@babel/preset-typescript": "^8.0.1",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "babel-jest": "^30.4.1",
        "babel-loader": "^10.1.1",
        "clean-css": "^5.3.3",
        "copy-webpack-plugin": "^14.0.0",
        "cross-env": "^10.1.0",
        "highlight.js": "^11.11.1",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "mikel": "^0.38.1",
        "mikel-cli": "^0.38.1",
        "mikel-frontmatter": "^0.38.1",
        "mikel-markdown": "^0.38.1",
        "mikel-press": "^0.38.1",
        "picomatch": "^4.0.4",
        "purgecss": "^8.0.0",
        "react-test-renderer": "^18.2.0",
        "serve": "^14.2.4",
        "typescript": "^6.0.3",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3"
    },
    "license": "MIT"
}
