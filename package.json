{
    "name": "folio",
    "version": "0.28.0",
    "description": "A minimalistic digital whiteboard for sketching and prototyping",
    "private": true,
    "type": "module",
    "homepage": "https://www.josemi.xyz/folio",
    "repository": "https://github.com/jmjuanes/folio",
    "author": "Josemi Juanes <hello@josemi.xyz>",
    "bugs": "https://github.com/jmjuanes/folio/issues",
    "workspaces": [
        "folio-react",
        "ai",
        "server",
        "apps/*"
    ],
    "scripts": {
        "build": "yarn build:studio",
        "build:ai": "yarn workspace folio-ai build",
        "build:app": "yarn build:studio",
        "build:dist": "cross-env NODE_ENV=production webpack build",
        "build:docs": "node scripts/site.js -c resources/sites/documentation.json -o .cache/documentation && node scripts/copy-assets.js -o .cache/documentation",
        "build:lite": "yarn workspace folio-lite build",
        "build:landing": "node scripts/site.js -c resources/sites/landing.json -o .cache/landing && node scripts/copy-assets.js -o .cache/landing",
        "build:server": "yarn workspace folio-server build",
        "build:studio": "yarn workspace folio-studio build",
        "build:website": "yarn build:lite && yarn build:docs && yarn build:landing",
        "prebuild:dist": "node scripts/obfuscate-css.js --input node_modules/lowcss/low.css --input node_modules/lowcss-helpers/index.css --output obfuscate.map.json",
        "postbuild:dist": "node scripts/purge-css.js --input folio-react/folio.js --output folio-react/folio.css --config obfuscate.map.json",
        "copy:app": "yarn copy:studio",
        "copy:studio": "yarn clean && cp -R apps/studio/www www",
        "copy:website": "yarn clean && mkdir www && cp -R .cache/documentation/* www && cp -R apps/lite/www/* www/ && cp -R .cache/landing/* www/",
        "clean": "rm -rf www",
        "deploy:ai": "yarn workspace folio-ai deploy",
        "dev": "serve www -p 8080",
        "dev:ai": "yarn workspace folio-ai dev",
        "dev:app": "yarn dev:studio",
        "dev:docs": "serve .cache/documentation -p 8080",
        "dev:landing": "serve .cache/landing -p 8080",
        "dev:lite": "cross-env NODE_ENV=development yarn workspace folio-lite dev",
        "dev:studio": "cross-env NODE_ENV=development yarn workspace folio-studio dev",
        "docker:studio": "docker build -f ./Dockerfile -t folio-studio .",
        "start": "cross-env NODE_ENV=development DEBUG='folio:*' node folio.js start",
        "ping": "cross-env NODE_ENV=development DEBUG='folio:*' node folio.js ping",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
        "typecheck": "yarn typecheck:server && yarn typecheck:ai",
        "typecheck:ai": "yarn workspace folio-ai typecheck",
        "typecheck:server": "yarn workspace folio-server typecheck",
        "typecheck:lite": "yarn workspace folio-lite typecheck",
        "typecheck:studio": "yarn workspace folio-studio typecheck"
    },
    "dependencies": {
        "@josemi-icons/svg": "^0.7.0",
        "lowcss": "^0.33.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@babel/core": "^7.25.7",
        "@babel/plugin-transform-runtime": "^7.25.7",
        "@babel/preset-env": "^7.25.7",
        "@babel/preset-react": "^7.25.7",
        "@babel/preset-typescript": "^7.27.1",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "babel-jest": "^30.0.0",
        "babel-loader": "^10.0.0",
        "clean-css": "^5.3.3",
        "copy-webpack-plugin": "^13.0.0",
        "cross-env": "^7.0.3",
        "highlight.js": "^11.11.1",
        "html-webpack-plugin": "^5.6.3",
        "jest": "^30.0.0",
        "jest-environment-jsdom": "^30.0.0",
        "mikel": "^0.38.1",
        "mikel-cli": "^0.38.1",
        "mikel-frontmatter": "^0.38.1",
        "mikel-markdown": "^0.38.1",
        "mikel-press": "^0.38.1",
        "picomatch": "^4.0.2",
        "purgecss": "^7.0.2",
        "react-test-renderer": "^18.2.0",
        "serve": "^14.2.4",
        "webpack": "^5.95.0",
        "webpack-cli": "^6.0.1"
    },
    "license": "MIT"
}